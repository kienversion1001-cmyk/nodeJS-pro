<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="laptopshop" />
    <meta name="author" content="tran kien" />
    <title>Dashboard -laptopshop </title>

    <link href="/admin/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>

<body class="sb-nav-fixed">
    <%- include('../layout/header'); -%>


        <div id="layoutSidenav">
            <%- include('../layout/sidenav'); -%>
                <div id="layoutSidenav_content">
                    <main>
                        <div class="container-fluid px-4">
                            <h1 class="mt-4">Manage orders</h1>
                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                                <li class="breadcrumb-item active">orders detail</li>
                            </ol>
                            <div>


                                <table class="table table-hover table-bordered">
                                    <thead>
                                        <tr>
                                            <th scope="col">product</th>
                                            <th scope="col">product name</th>
                                            <th scope="col">price</th>
                                            <th scope="col">quantity</th>
                                            <th scope="col">total price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (!orderDetails || orderDetails.length===0) { %>
                                            <tr>
                                                <td colspan="7" class="text-center text-muted">
                                                    注文がありません
                                                </td>
                                            </tr>
                                            <% } else { %>

                                                <% orderDetails.forEach(function(orderDetail) { %>
                                                    <tr>
                                                        <th scope="row">
                                                            <%= orderDetail.product.name %>
                                                        </th>

                                                        <td>
                                                            <div>
                                                                <img src="/images/product/<%= orderDetail.product.image %>"
                                                                    class="img-fluid me-5 rounded-circle"
                                                                    style="max-height: 80px; border-radius: 8px;">
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <%= new Intl.NumberFormat('ja-JP', { style: 'currency' ,
                                                                currency: 'JPY' }).format(orderDetail.price) %>

                                                        </td>
                                                        <td>
                                                            <%= orderDetail.quantity %>
                                                        </td>
                                                        <td>
                                                            <%= new Intl.NumberFormat('ja-JP', { style: 'currency' ,
                                                                currency: 'JPY' }).format(orderDetail.quantity *
                                                                orderDetail.price) %>

                                                        </td>



                                                    </tr>
                                                    <% }); %>

                                                        <% } %>
                                    </tbody>





                                </table>




                            </div>
                            <a href="/admin/orders" class="btn btn-primary">Back</a>
                        </div>

                    </main>

                    <%- include('../layout/footer'); -%>
                </div>

        </div>



        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
        <script src="/admin/js/scripts.js"></script>


</body>

</html>