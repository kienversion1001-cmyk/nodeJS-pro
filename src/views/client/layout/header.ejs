<div class="container-fluid ">
    <div class="container topbar bg-primary d-none d-lg-block">
        <div class="d-flex justify-content-between">
            <div class="top-info ps-2">
                <% if (user) { %>
                    <!-- ログイン時：ユーザー情報を表示 -->
                    <small class="me-3">
                        <i class="fas fa-map-marker-alt me-2 text-secondary"></i>
                        <a href="#" class="text-white">
                            <%= user.address ? user.address : "" %>
                        </a>
                    </small>
                    <small class="me-3">
                        <i class="fas fa-envelope me-2 text-secondary"></i>
                        <a href="#" class="text-white">
                            <%= user.username ? user.username : "" %>
                        </a>
                    </small>
                    <% } else { %>
                        <!-- 未ログイン時：ログインアイコンを表示 -->
                        <small class="me-3">
                            <a href="/login" class="text-white">
                                <i class="fas fa-sign-in-alt me-2"></i>ログイン
                            </a>
                        </small>
                        <small class="me-3">
                            <a href="/register" class="text-white">
                                <i class="fas fa-user-plus me-2"></i>新規登録
                            </a>
                        </small>
                        <% } %>
            </div>
            <div class="top-link pe-2">
                <a href="#" class="text-white"><small class="text-white mx-2">Privacy Policy</small>/</a>
                <a href="#" class="text-white"><small class="text-white mx-2">Terms of Use</small>/</a>

            </div>
        </div>
    </div>
    <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-xl">
            <a href="/" class="navbar-brand">
                <h1 class="text-primary display-6">laptopshop</h1>
            </a>
            <button class="navbar-toggler py-2 px-3" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarCollapse">
                <span class="fa fa-bars text-primary"></span>
            </button>
            <div class="collapse navbar-collapse bg-white" id="navbarCollapse">
                <div class="navbar-nav mx-auto">
                    <a href="/" class="nav-item nav-link ">Home</a>
                    <a href="/products" class="nav-item nav-link">product</a>

                </div>
                <div class="d-flex m-3 me-0">

                    <a href="/cart" class="position-relative me-4 my-auto">
                        <i class="fa fa-shopping-bag fa-2x"></i>
                        <span
                            class="position-absolute bg-secondary rounded-circle d-flex align-items-center justify-content-center text-dark px-1"
                            style="top: -5px; left: 15px; height: 20px; min-width: 20px;" id="sumCart">
                            <%= user?.sumCart ?? 0%>
                        </span>
                    </a>
                    <div class="dropdown my-auto">
                        <a href="#" class="dropdown" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown"
                            aria-expanded="false" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user fa-2x"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end p-4" aria-labelledby="dropdownMenuLink">
                            <% if (user) { %>
                                <li class="d-flex align-items-center flex-column" style="min-width: 300px;">
                                    <img style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden;"
                                        src="/images/ <%=user?.avatar??""%>" />
                                    <div class="text-center my-3">
                                        <%=user?.fullName??""%>
                                    </div>
                                </li>

                                <li><a class="dropdown-item" href="#">アカウント管理</a></li>

                                <li><a class="dropdown-item" href="/order-history">購入履歴</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <form method="post" action="/logout">
                                        <button class="dropdown-item">ログアウト</button>
                                    </form>
                                </li>
                                <% } else { %>
                                    <li>
                                        <a class="dropdown-item a-login" href="/login">
                                            <i class="fas fa-sign-in-alt me-2"></i>ログイン
                                        </a>
                                    </li>
                                    <% } %>
                        </ul>
                    </div>

                </div>
            </div>
        </nav>
    </div>
</div>